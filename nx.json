{
  "extends": "@nx/workspace/presets/npm.json",
  "defaultBase": "master",
  "useInferencePlugins": false,
  "namedInputs": {
    "production": [
      "default",
      "!{projectRoot}/**/*.test.{ts,js}",
      "!{projectRoot}/vitest.config.ts"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "prepare": {
      "dependsOn": ["^prepare"]
    },
    "package": {
      "dependsOn": ["^package"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^default", "{workspaceRoot}/vitest.config.ts", "{projectRoot}/vitest.config.ts"]
    },
    "@nx/eslint:lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/.eslintrc.yaml"]
    }
  }
}

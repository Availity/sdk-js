{
  "name": "@availity/dl-axios",
  "version": "8.1.0",
  "description": "Utility to download files from services",
  "keywords": [
    "download",
    "file",
    "availity"
  ],
  "homepage": "https://availity.github.io/sdk-js/api/downloads",
  "bugs": {
    "url": "https://github.com/availity/sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/availity/sdk-js.git",
    "directory": "packages/dl-axios"
  },
  "license": "MIT",
  "author": "Robert McGuinness",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.js --format esm --clean --dts --target esnext",
    "dev": "tsup src/index.js --format esm --watch --dts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public",
    "test": "vitest run"
  },
  "dependencies": {
    "@availity/api-core": "workspace:*",
    "@availity/dl-core": "workspace:*"
  },
  "devDependencies": {
    "axios": "^1.17.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "axios": "^1.17.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}

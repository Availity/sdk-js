{
  "name": "@availity/user-activity-broadcaster",
  "version": "2.0.0",
  "description": "This package broacasts user activity to the navigation.",
  "keywords": [],
  "homepage": "https://availity.github.io/sdk-js/resources/user-activity-broadcaster",
  "bugs": {
    "url": "https://github.com/availity/sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/availity/sdk-js.git",
    "directory": "packages/user-activity-broadcaster"
  },
  "license": "MIT",
  "author": "Joe Spanbauer <joseph.spanbauer@availity.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.js --format esm,cjs --dts",
    "dev": "tsup src/index.js --format esm,cjs --watch --dts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf node_modules && rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}

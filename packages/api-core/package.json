{
  "name": "@availity/api-core",
  "version": "13.0.1",
  "description": "Base API definitions for the Availity REST API",
  "keywords": [
    "availity",
    "api",
    "http",
    "rest"
  ],
  "homepage": "https://availity.github.io/sdk-js/api/getting-started",
  "bugs": {
    "url": "https://github.com/Availity/sdk-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Availity/sdk-js.git",
    "directory": "packages/api-core"
  },
  "license": "MIT",
  "author": "Kasey Powers <kasey.powers@availity.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "build": "tsup src/index.js --format esm --clean --dts",
    "dev": "tsup src/index.js --format esm --watch --dts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf node_modules && rm -rf dist",
    "publish": "yarn npm publish --tolerate-republish --access public"
  },
  "dependencies": {
    "@availity/env-var": "workspace:*",
    "@availity/resolve-url": "workspace:*",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
